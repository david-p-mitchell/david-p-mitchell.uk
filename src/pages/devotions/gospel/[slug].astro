---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { codeToHtml } from "shiki";

export async function getStaticPaths() {
  const devotions = await getCollection("devdevotions");

  return devotions.map((devotion) => ({
    params: {
      slug: devotion.id,
    },
    props: {
      devotion,
    },
  }));
}

const { devotion } = Astro.props;
const { Content } = await render(devotion);

const highlightedCode = await codeToHtml(devotion.data.code, {
  lang: "csharp",
  theme: "dark-plus",
});
---

<BaseLayout>
    <article class="prose flex flex-col mx-auto py-8  ">
        <div class="mx-auto bg-blue-950 p-4 text-white rounded-lg border border-blue-800 max-w-[90%] sm:max-w-md md:max-w-2xl lg:max-w-4xl">
        <h1 class="text-xl font-bold" >{devotion.data.title}</h1>

        <p class="text-xl font-semibold">{devotion.data.verse}</p>
        <div class="overflow-x-auto  sm:max-w-md md:max-w-full bg-[#1E1E1E]" set:html={highlightedCode} />
        
        <br />
        
        </div>
        <div class="mx-auto bg-blue-950 p-4 text-white rounded-lg border border-blue-800 mt-4 max-w-4xl ">
          <div class="max-w-2xl mx-auto x-overflow min-w-[90%] [&>p]:mb-4 [&>p]:leading-7 [&>p]:text-zinc-300 [&>p]:text-lg [&>p]:font-light
        [&>h1]:text-4xl
        [&>h1]:font-bold
        [&>h1]:mb-6

        [&>h2]:mt-8
        [&>h2]:mb-4
        [&>h2]:text-2xl
        [&>h2]:font-semibold

        [&>p]:mb-4
        [&>p]:leading-7">
            <Content />
          </div>
        </div>
        
    </article>

    <script is:inline>
    var refTagger = {
      settings: {
        bibleVersion: "ESV",
        roundCorners: true,
        socialSharing: [],
      },
    };
  </script>

  <script is:inline src="https://api.reftagger.com/v2/RefTagger.js"  />
</BaseLayout>