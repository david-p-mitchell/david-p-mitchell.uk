
	---
  import Layout from "../layouts/Layout.astro";
// src/pages/index.astro
const sections = [
  {
    title: "Resources",
    links: [
      { name: "Bible Gateway", url: "https://www.biblegateway.com" },
      { name: "Blue Letter Bible", url: "https://www.blueletterbible.org" }
    ]
  },
  {
    title: "Christian Documentaries",
    links: [
      { name: "From the Rising of the Sun", url: "https://watch.studygateway.com/products/from-the-rising-of-the-sun", publiclyFree: false }
    ]
  },
  {
    title: "Reformed Blogs",
    links: [
      { name: "Ligonier Ministries", url: "https://www.ligonier.org" },
      { name: "The Gospel Coalition", url: "https://www.thegospelcoalition.org" }
    ]
  }
];
---

<html lang="en">
<Layout>
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>My Links</title>
  </head>
  
  <body class="bg-blue-950 text-slate-200 min-h-screen">
    <h1 class="text-3xl font-bold text-center mb-8">Useful Links</h1>

    <div class="grid gap-6 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
      {sections.map(section => (
        <div class="bg-slate-800 rounded-2xl p-5 shadow-lg">
          <h2 class="text-xl font-semibold mb-3">{section.title}</h2>
          <ul class="space-y-2">
            {section.links.map(link => (
              <li>
                <a href={link.url} target="_blank" class="text-sky-400 hover:underline">
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </body>
  </Layout>
</html>

