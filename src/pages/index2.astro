---
// src/pages/index.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import AboutCard from "../components/AboutCard.astro";
import VerseCard from "../components/VerseCard.astro";
import EncouragementBanner from "../components/EncouragementBanner.astro";
import DailyFocus from "../components/DailyFocus.astro";

// ── Edit these to personalise ──────────────────────────────────────────────
const me = {
  name: "Your Name",
  role: "Developer · Follower of Christ",
  bio:
    "I build things for the web and try to do it for God's glory. " +
    "Coffee enthusiast, lover of good books, and endlessly curious " +
    "about where technology and faith intersect.",
  // Place your photo at /public/images/profile.jpg in your Astro project
  imageSrc: "/images/profile.jpg",
};

const verses = [
  {
    verse:
      "I can do all things through Christ who strengthens me.",
    reference: "Philippians 4:13",
    icon: "✦",
  },
  {
    verse:
      "Trust in the Lord with all your heart and lean not on your own understanding.",
    reference: "Proverbs 3:5",
    icon: "☩",
  },
  {
    verse:
      "For I know the plans I have for you, declares the Lord — plans to prosper you and not to harm you.",
    reference: "Jeremiah 29:11",
    icon: "✦",
  },
  {
    verse:
      "Be still, and know that I am God.",
    reference: "Psalm 46:10",
    icon: "☩",
  },
];

const focusItems = [
  { label: "Theme", value: "Walk humbly, love mercy, seek justice" },
  { label: "Prayer", value: "Gratitude · Discernment · Peace" },
  { label: "Reading", value: "Psalm 23 · Romans 8" },
];
// ────────────────────────────────────────────────────────────────────────────
---

<BaseLayout title={`${me.name} — Home`}>
  
  <div class="page-shell">
    <!-- Ambient background dots -->
    <div class="bg-dots" aria-hidden="true"></div>

    <!-- ── Header / Nav ─────────────────────────────────────── -->
    

    <!-- ── Main dashboard grid ──────────────────────────────── -->
    <main class="dashboard">

      <!-- Row 1: About (large left) + banner (right) -->
      <section id="about" class="grid-area about-area" style="animation-delay: 0.05s">
        <AboutCard
          name={me.name}
          role={me.role}
          bio={me.bio}
          imageSrc={me.imageSrc}
        />
      </section>

      <section class="grid-area banner-area" style="animation-delay: 0.1s">
        <EncouragementBanner
          message="You are fearfully and wonderfully made."
          subtext="Psalm 139:14 — Walk in that truth today."
        />

        <!-- Tiny stat chips row inside the banner column -->
        <div class="chip-row">
          <div class="chip">
            <span class="chip-label">Grace</span>
            <span class="chip-value">Undeserved ∞</span>
          </div>
          <div class="chip">
            <span class="chip-label">Strength</span>
            <span class="chip-value">His, not mine</span>
          </div>
          <div class="chip">
            <span class="chip-label">Purpose</span>
            <span class="chip-value">Glorify God</span>
          </div>
        </div>
      </section>

      <!-- Row 2: Scripture cards -->
      <!-- <section id="faith" class="grid-area verses-heading-area">
        <h3 class="section-heading">
          <span class="heading-line"></span>
          Scripture Encouragements
        </h3>
      </section>

      {verses.map((v, i) => (
        <div
          class="grid-area verse-area"
          style={`animation-delay: ${0.15 + i * 0.07}s`}
        >
          <VerseCard verse={v.verse} reference={v.reference} icon={v.icon} />
        </div>
      ))} -->

      <!-- Row 3: Daily Focus -->
      <section id="focus" class="grid-area focus-area" style="animation-delay: 0.45s">
        <DailyFocus title="Today's Focus" focusItems={focusItems} />
      </section>

      <!-- Quote / final encouragement -->
      <div class="grid-area closing-area" style="animation-delay: 0.5s">
        <div class="closing-quote">
          <p class="closing-text">
            "Let your light shine before others, that they may see your good deeds
            and glorify your Father in heaven."
          </p>
          <cite class="closing-ref">Matthew 5:16</cite>
        </div>
      </div>

    </main>

    <footer class="site-footer">
      <span>Made with faith &amp; coffee · {new Date().getFullYear()}</span>
    </footer>
  </div>
</BaseLayout>

<style>
  /* ── Shell & layout ──────────────────────────────────────── */
  .page-shell {
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
    position: relative;
    margin-top:20px;
  }

  .bg-dots {
    position: fixed;
    inset: 0;
    background-image: radial-gradient(circle, #ffffff08 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
    z-index: 0;
  }

  /* ── Header ─────────────────────────────────────────────── */
  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.75rem 0 2rem;
    position: relative;
    z-index: 1;
  }

  .site-logo {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--accent-gold);
    letter-spacing: 0.04em;
  }

  .site-nav {
    display: flex;
    gap: 2rem;
  }

  .site-nav a {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .site-nav a:hover {
    color: var(--accent-gold);
  }

  /* ── Dashboard grid ─────────────────────────────────────── */
  .dashboard {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    grid-template-rows: auto auto auto auto auto;
    gap: 1rem;
    position: relative;
    z-index: 1;
  }

  .grid-area {
    animation: fadeUp 0.5s ease both;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Grid placements */
  .about-area       { grid-column: 1 / 3; grid-row: 1; }
  .banner-area      { grid-column: 3 / 5; grid-row: 1; display: flex; flex-direction: column; gap: 1rem; }

  .verses-heading-area { grid-column: 1 / 5; grid-row: 2; }

  /* Four verse cards in a row */
  .verse-area       { grid-row: 3; }
  .verse-area:nth-child(4) { grid-column: 1; }
  .verse-area:nth-child(5) { grid-column: 2; }
  .verse-area:nth-child(6) { grid-column: 3; }
  .verse-area:nth-child(7) { grid-column: 4; }

  .focus-area       { grid-column: 1 / 3; grid-row: 4; }
  .closing-area     { grid-column: 3 / 5; grid-row: 4; }

  /* ── Section heading ────────────────────────────────────── */
  .section-heading {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin: 0.5rem 0 0;
  }

  .heading-line {
    flex: 0 0 28px;
    height: 1px;
    background: var(--border);
  }

  /* ── Chip row ───────────────────────────────────────────── */
  .chip-row {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .chip {
    flex: 1;
    min-width: 90px;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 0.85rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .chip-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .chip-value {
    font-size: 0.82rem;
    color: var(--text-primary);
  }

  /* ── Closing quote ──────────────────────────────────────── */
  .closing-quote {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.75rem 2rem;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.9rem;
    position: relative;
    overflow: hidden;
  }

  .closing-quote::before {
    content: "❝";
    position: absolute;
    top: -0.5rem;
    right: 1rem;
    font-family: var(--font-serif);
    font-size: 5rem;
    color: var(--accent-gold);
    opacity: 0.06;
    line-height: 1;
    pointer-events: none;
  }

  .closing-text {
    font-family: var(--font-serif);
    font-size: 0.98rem;
    font-style: italic;
    line-height: 1.7;
    color: var(--text-primary);
  }

  .closing-ref {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--accent-gold);
    letter-spacing: 0.08em;
    font-style: normal;
  }

  /* ── Footer ─────────────────────────────────────────────── */
  .site-footer {
    margin-top: 3rem;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    position: relative;
    z-index: 1;
  }

  /* ── Responsive ─────────────────────────────────────────── */
  @media (max-width: 768px) {
    .dashboard {
      grid-template-columns: 1fr 1fr;
    }

    .about-area       { grid-column: 1 / 3; }
    .banner-area      { grid-column: 1 / 3; }
    .verses-heading-area { grid-column: 1 / 3; }
    .verse-area       { grid-column: auto !important; }
    .focus-area       { grid-column: 1 / 3; }
    .closing-area     { grid-column: 1 / 3; }
  }

  @media (max-width: 480px) {
    .dashboard {
      grid-template-columns: 1fr;
    }

    .about-area,
    .banner-area,
    .verses-heading-area,
    .verse-area,
    .focus-area,
    .closing-area {
      grid-column: 1 !important;
    }
  }
</style>
