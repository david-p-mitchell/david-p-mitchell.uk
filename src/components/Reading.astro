---
import BibleReading from "./BibleReading.astro";
import readings from "../data/bibleReading.ts";
import type { Book } from '../data/books'
interface Props {
  books: Book[];
}
const { books } = Astro.props;
---

<section class="bg-card border border-border pt-4 px-4 flex flex-col overflow-y-auto w-sm:max-w-md sm:rounded-lg lg:rounded-2xl">
  
  <p class="font-mono text-xs uppercase tracking-widest text-gold-muted">Currently Reading</p>
  
  <BibleReading readings={readings} />
  <p class="pb-4 font-display font-semibold text-sm text-text-primary leading-snug">Books Reading ({books.filter((book) => book.show ?? true).length})</p>
  <ul
  class={`flex flex-col gap-4 overflow-y-auto pr-1 scrollbar-thin scrollbar-thumb-border scrollbar-track-transparent ${
    readings?.length > 0 ? "max-h-[200px]" : "max-h-[400px]"
  }`}
>
    {books.filter((book) => book.show ?? true).sort((a, b) => (b.progress ?? 0) - (a.progress ?? 0)).map(book => (
      <li class="flex items-start gap-4">

        <!-- Book spine block -->
        {book.img ? (
        <img
            src={book.img}
            alt={book.title}
            class="w-9 h-14 object-cover rounded-sm shrink-0"
        />
        ) : (
        <div
            class="shrink-0 w-9 h-14 rounded-sm flex items-center justify-center overflow-hidden"
            style={{ backgroundColor: book.coverColor ?? "#252d40" }}
        >
            <span class="text-white text-[9px] font-mono font-semibold uppercase opacity-70 [writing-mode:vertical-rl] tracking-widest">
            {book.title.slice(0, 8)}
            </span>
        </div>
        )}

        <div class="flex flex-col gap-1.5 flex-1 min-w-0">
          <p class="font-display font-semibold text-sm text-text-primary leading-snug">{book.title}</p>
          <p class="font-display text-xs text-gray-100 pr-2">
            {book.author}
            { (book.tags?.length ?? 0) > 0 && (
              <span class="gap-2 mt-2 ">
                {book.tags!.map((tag) => (
                  <span class="mx-1 px-1 py-0.5 bg-gold text-blue-950 text-[9px] font-semibold rounded-full">
                    {tag}
                  </span>
                ))}
              </span>
            )}
          </p>

          {book.progress !== undefined && (
            <div class="flex items-center gap-2 mt-0.5">
              <div class="flex-1 h-1 bg-border rounded-full overflow-hidden">
                <div
                  class="h-full bg-gold rounded-full transition-all duration-700"
                  style={`width: ${book.progress}%`}
                ></div>
              </div>
              <span class="font-mono text-xs text-text-muted shrink-0 pr-2 md:pr-0">{book.progress}%</span>
            </div>
          )}
        </div>

      </li>
    ))}
  </ul>

</section>