---
interface Props {
  verse: string;
  reference: string;
}
const { verse, reference } = Astro.props;
---

<section class="bg-card border border-border rounded-2xl p-6 flex flex-col gap-4 relative overflow-hidden">

  <!-- Decorative large quote mark -->
  <span class="absolute top-3 right-5 font-serif text-7xl text-gold opacity-10 leading-none pointer-events-none select-none" aria-hidden="true">
    ❝
  </span>

  <p class="font-mono text-xs uppercase tracking-widest text-gold-muted">Daily Verse</p>

  <blockquote class="font-serif italic text-lg leading-relaxed text-text-primary">
    "{verse}"
  </blockquote>

  <cite class="font-mono not-italic text-xs tracking-wider text-gold">
    — {reference}
  </cite>

  <!-- Gold bottom accent line -->
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-gold via-gold-muted to-transparent opacity-40"></div>

</section>