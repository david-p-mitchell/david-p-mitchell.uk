---
interface Props {
  name: string;
  role: string;
  bio: string;
  imageSrc?: string;
}
const { name, role, bio, imageSrc = "/images/me.jpg" } = Astro.props;
---

<section class="bg-card border border-border sm:rounded-lg lg:rounded-2xl p-3">
  
  <!-- Top row -->
  <div class="flex gap-4 items-center">
    
    <div class="relative shrink-0 w-20 h-20">
      <img
        src={imageSrc}
        alt={`Photo of ${name}`}
        class="w-[76px] h-[76px] rounded-full object-cover object-top"
      />
      <div class="photo-ring"></div>
    </div>

    <div class="flex flex-col gap-1 text-left">
      <p class="font-mono text-xs uppercase tracking-widest text-gold-muted">About Me</p>
      <h2 class="font-display font-bold text-2xl text-text-primary leading-tight">{name}</h2>
      <p class="font-mono text-xs tracking-wide text-gold">{role}</p>
    </div>

  </div>

  <!-- Bio row -->
  <p class="font-serif text-sm leading-relaxed text-text-secondary mt-3">
    {bio}
  </p>

</section>