---
interface Props {
  name: string;
  role: string;
  bio: string;
  imageSrc?: string;
}
const { name, role, bio, imageSrc = "/images/me.jpg" } = Astro.props;
---

<section class="bg-card border border-border rounded-2xl p-2 flex gap-2 items-start h-full">
    <div>
<div class="flex">
  <!-- Circular photo with spinning ring -->
  <div class="relative shrink-0 w-20 h-20">
    <a href="/me" class="absolute inset-0 z-20 rounded-full focus:outline-none focus:ring-2 focus:ring-gold">
      
    <img
      src={imageSrc}
      alt={`Photo of ${name}`}
      class="relative z-10 w-[76px] h-[76px] rounded-full object-cover object-top w-full h-64"
    />
    <div class="photo-ring"></div>
    </a>
  </div>

  <!-- Text -->
  <div class="flex flex-col gap-1.5 text-left pl-4">
    <p class="font-mono text-xs uppercase tracking-widest text-gold-muted">About Me</p>
    <h2 class="font-display font-bold text-2xl text-text-primary leading-tight">{name}</h2>
    <p class="font-mono text-xs tracking-wide text-gold">{role}</p>
    
  </div>
  </div>
  <div class="inline-block">
<p class="font-serif text-sm leading-relaxed text-text-secondary mt-1">{bio}</p>
</div>
</div>
</section>