---
import { Code } from 'astro:components';
import type { CodeLanguage } from 'astro';

interface Props {
  title: string;
  code: string;
  lang?: CodeLanguage;
  description?: string;
}

const {
  title,
  code,
  lang = 'csharp',
  description
} = Astro.props;
---

<section class="bg-card border border-border p-2 flex flex-col gap-4 sm:rounded-lg lg:rounded-2xl min-w-sm">
  <div>
    <p class="font-mono text-xs uppercase tracking-widest text-gold-muted">
      Featured Code
    </p>

    <h3 class="font-display font-semibold text-text-primary mt-2">
      {title}
    </h3>

    {description && (
      <p class="text-sm text-text-muted mt-1">
        {description}
      </p>
    )}
  </div>

  <div class="overflow-hidden rounded-lg border border-border">
    <Code code={code} lang={lang} />
  </div>
</section>