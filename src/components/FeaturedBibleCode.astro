---
import { Code } from 'astro:components';
import type { CodeLanguage } from 'astro';

interface Props {
  description?: string;
}

const { description } = Astro.props;

const files = import.meta.glob('/src/code-snippets/*.md', {
  query: '?raw',
  import: 'default',
  eager: true
});

// Pick a deterministic "random" file for today
const paths = Object.keys(files).sort();

const today = new Date().toISOString().slice(0, 10);

const hash = [...today].reduce(
  (acc, char) => ((acc << 5) - acc + char.charCodeAt(0)) | 0,
  0
);
console.log(paths)
const selectedPath = paths[Math.abs(hash) % paths.length];
const content = files[selectedPath] as string;

// Parse the file
const lines = content.trim().split('\n');
const title = lines[0].trim();

const codeMatch = content.match(
  /```(?<lang>[^\n]*)\n(?<code>[\s\S]*?)```/
);

const lang = (codeMatch?.groups?.lang?.trim() ||
  'csharp') as CodeLanguage;

const code = codeMatch?.groups?.code?.trim() ?? '';
---

<section class="bg-card border border-border p-2 flex flex-col gap-4 sm:rounded-lg lg:rounded-2xl min-w-sm">
  <div>
    <p class="font-mono text-xs uppercase tracking-widest text-gold-muted">
      Featured Code
    </p>

    <h3 class="font-display font-semibold text-text-primary mt-2">
      {title}
    </h3>

    {description && (
      <p class="text-sm text-text-muted mt-1">
        {description}
      </p>
    )}
  </div>

  <div class="overflow-hidden rounded-lg border border-border">
    <Code code={code} lang={lang} />
  </div>
</section>