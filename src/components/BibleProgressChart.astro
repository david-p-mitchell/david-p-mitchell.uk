---
export type Reading = {
  book: string;
  progress: number;
  lastRead: Date | string;
};

import { bibleBooks, abbreviations } from "../data/bibleBooks.ts";

const readings: Reading[] = Astro.props.readings ?? [];

const progressMap = new Map(
  readings.map(r => [r.book.toLowerCase(), r.progress])
);

const data = bibleBooks.map(book => ({
  book,
  short: abbreviations[book] ?? book.slice(0, 3),
  progress: progressMap.get(book.toLowerCase()) ?? 0
}));

// Layout constants (px) — bar height and the reference line share these,
// so a 100%-progress bar's top edge always lines up with the red line.
const BAR_MAX_HEIGHT = 100; // height of a 100% bar

// Gradient endpoints: blue-600 → green-600 (Tailwind's own values, so the
// bar colour stays visually consistent with the rest of the palette).
const COLOR_START = { r: 0x25, g: 0x63, b: 0xeb }; // blue-600
const COLOR_END = { r: 0x16, g: 0xa3, b: 0x4a };   // green-600

function progressColor(progress: number): string {
  const t = Math.min(1, Math.max(0, progress / 100)); // clamp 0–1
  const r = Math.round(COLOR_START.r + (COLOR_END.r - COLOR_START.r) * t);
  const g = Math.round(COLOR_START.g + (COLOR_END.g - COLOR_START.g) * t);
  const b = Math.round(COLOR_START.b + (COLOR_END.b - COLOR_START.b) * t);
  return `rgb(${r}, ${g}, ${b})`;
}
---

<div class="overflow-x-auto overflow-y-visible">
  <div class="relative flex items-end gap-[0.5px] min-w-max border-b border-gray-300 px-1 pb-1">
    <div class="absolute left-0 right-0 top-0 flex items-center border-t border-gray-100 opacity-40"/>
    {data.map((item) => (
      <div
        class="flex flex-col items-center w-[14px] gap-1"
        title={`${item.book}: ${item.progress}%`}
      >
        <div class="flex items-end" style={`height: ${BAR_MAX_HEIGHT}px`}>
          <div
            class="w-[8px] rounded-t"
            style={`height: ${item.progress * (BAR_MAX_HEIGHT / 100)}px; background-color: ${progressColor(item.progress)}`}
          />
        </div>
        <div class="h-4 text-[8px] text-gray-500 leading-none text-center rotate-[270deg]">
          {item.short}
        </div>
      </div>
    ))}
  </div>
</div>