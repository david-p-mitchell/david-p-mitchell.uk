---
interface Reading {
  book: string;
  progress: number;
  lastRead: string | Date;
}

interface Props {
  readings: Reading[];
}
const { readings } = Astro.props;

function formatDate(dateString: string | Date): string {
  const date = new Date(dateString);
  const now = new Date();

  // Normalize to midnight for accurate day diff
  const startOfToday = new Date(now.getFullYear(), now.getMonth(), now.getDate());
  const startOfDate = new Date(date.getFullYear(), date.getMonth(), date.getDate());

  const diffMs = startOfToday.getTime() - startOfDate.getTime();
  const diffDays = Math.round(diffMs / (1000 * 60 * 60 * 24));

  if (diffDays === 0) return "Today";
  if (diffDays === 1) return "Yesterday";
  if (diffDays < 7) return `${diffDays} days ago`;

  return date.toLocaleDateString(undefined, {
    month: "short",
    day: "numeric",
    year: "numeric",
  });
}

// optional: clean + sort data once
const activeReadings = readings
  ?.filter(r => r?.book)
  .slice()
  .sort(
    (a, b) =>
      new Date(b.lastRead).getTime() -
      new Date(a.lastRead).getTime()
  );
---

{activeReadings?.length > 0 && (
  <div class="flex gap-4 overflow-x-auto snap-x snap-mandatory pb-4 text-white scrollbar-thin scrollbar-thumb-border scrollbar-track-transparent">
    {activeReadings.map((reading) => (
      <article
        class="min-w-[150px] snap-start rounded-xl border border-slate-200 px-2 py-1 shadow-sm"
      >
        <!-- TOP ROW -->
        <div class="flex items-center justify-between">
          <h3 class="text-sm font-semibold truncate">
            {reading.book}
          </h3>

          <span class="text-xs text-slate-400">
            {reading.progress}%
          </span>
        </div>

        <!-- PROGRESS BAR -->
        <div class="mt-2 h-1 rounded-full bg-slate-200">
          <div
            class="h-1 rounded-full bg-blue-600"
            style={`width: ${reading.progress}%`}
          />
        </div>

        <!-- BOTTOM ROW -->
        <div class="mt-2 flex items-center justify-between text-xs text-slate-500">
          <span>Last read</span>

          <span class="text-slate-300">
            {formatDate(reading.lastRead)}
          </span>
        </div>
      </article>
    ))}
  </div>
)}