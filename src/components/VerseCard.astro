---
interface Props { verse: string; reference: string; icon?: string; }
const { verse, reference, icon = "✦" } = Astro.props;
---

<div class="vbar h-full flex flex-col rounded-2xl p-6
            bg-card border border-rim
            transition-all duration-300 hover:-translate-y-0.5 hover:shadow-gold-sm">

  <span class="block text-base text-gold opacity-75 mb-2">{icon}</span>

  <blockquote class="font-serif italic text-sm leading-relaxed text-text-primary flex-1 mb-3">
    "{verse}"
  </blockquote>

  <cite class="font-mono not-italic text-xs tracking-wider text-gold">
    — {reference}
  </cite>
</div>