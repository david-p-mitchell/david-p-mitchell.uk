---
// Astro Frontmatter: Runs ONLY at build time on your server/CI.
// Fetches playlist once and creates a static video array.

const PLAYLIST_ID = "PL4eoRWZvm-i1RhwritYSbfqVCTD8jDmQV";

type VideoData = {
  id: string;
  title: string;
};

let videoDataArray: VideoData[] = [];

try {
  const res = await fetch(
    `https://www.youtube.com/feeds/videos.xml?playlist_id=${PLAYLIST_ID}`
  );

  if (res.ok) {
    const xml = await res.text();
    const entryMatches = [...xml.matchAll(/<entry>([\s\S]*?)<\/entry>/g)];

    videoDataArray = entryMatches
      .map((entry) => {
        const block = entry[1];

        const idMatch = block.match(/<yt:videoId>(.*?)<\/yt:videoId>/);
        const titleMatch = block.match(/<title>(.*?)<\/title>/);

        const id = idMatch?.[1];
        const title = titleMatch?.[1];

        if (!id) return null;

        const decodedTitle = (title ?? "YouTube Video")
          .replace(/&amp;/g, "&")
          .replace(/&quot;/g, '"')
          .replace(/&#39;/g, "'")
          .replace(/&lt;/g, "<")
          .replace(/&gt;/g, ">");

        return {
          id,
          title: decodedTitle
        };
      })
      .filter((video): video is VideoData => video !== null);
  }
} catch (error) {
  console.error("Build-time fetch failed:", error);
}
---

<section class="bg-card border border-border sm:rounded-lg lg:rounded-2xl overflow-hidden flex flex-col">

  <p class="font-mono text-xs uppercase tracking-widest text-gold-muted mt-4 ml-4">
    Today's Video Encouragement
  </p>

  <p 
    id="video-title"
    class="font-display font-semibold text-sm text-text-primary leading-snug ml-4 min-h-[1.25rem]"
  >
    Loading today's encouragement...
  </p>

  <div class="relative aspect-video mt-1">

    <iframe
      id="video-iframe"
      src=""
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      class="w-full h-full border-0 hidden"
    ></iframe>

    <div 
      id="video-skeleton"
      class="absolute inset-0 bg-muted/20 animate-pulse flex items-center justify-center"
    >
      <span class="text-xs text-text-secondary">
        Preparing video...
      </span>
    </div>

  </div>


  <div class="flex justify-between items-center p-4 gap-3">

    <button
      id="previous-video"
      class="px-4 py-2 text-xs rounded-lg border border-border disabled:opacity-40 text-white"
    >
      Previous
    </button>

    <span
      id="video-counter"
      class="text-xs text-text-secondary"
    >
      1 / 3
    </span>

    <button
      id="next-video"
      class="px-4 py-2 text-xs rounded-lg border border-border-white text-white/75 disabled:opacity-10"
    >
      Next Encouragement
    </button>

  </div>

</section>


<script define:vars={{ videoDataArray }}>

function seededRandom(seed) {
  let t = seed + 0x6D2B79F5;

  return function () {
    t += 0x6D2B79F5;

    let r = Math.imul(t ^ (t >>> 15), 1 | t);
    r ^= r + Math.imul(r ^ (r >>> 7), 61 | r);

    return ((r ^ (r >>> 14)) >>> 0) / 4294967296;
  };
}


function shuffle(array, random) {
  const copy = [...array];

  for (let i = copy.length - 1; i > 0; i--) {
    const j = Math.floor(random() * (i + 1));
    [copy[i], copy[j]] = [copy[j], copy[i]];
  }

  return copy;
}


function loadDailyVideos() {

  const titleEl = document.getElementById("video-title");
  const iframeEl = document.getElementById("video-iframe");
  const skeletonEl = document.getElementById("video-skeleton");

  const nextBtn = document.getElementById("next-video");
  const prevBtn = document.getElementById("previous-video");
  const counterEl = document.getElementById("video-counter");


  if (!videoDataArray || videoDataArray.length === 0) {
    titleEl.textContent =
      "Check back later for daily encouragement!";

    skeletonEl.classList.add("hidden");
    return;
  }


  const day = Math.floor(Date.now() / 86400000);

  const random = seededRandom(day);


  // Pick today's main video
  const todayIndex =
    day % videoDataArray.length;


  const used = new Set([todayIndex]);


  // Pick two random extras
  const extras = shuffle(
    videoDataArray
      .map((_, index) => index)
      .filter(index => !used.has(index)),
    random
  ).slice(0, 2);


  const dailyVideos = [
    videoDataArray[todayIndex],
    ...extras.map(index => videoDataArray[index])
  ];


  let currentVideo = 0;


  function showVideo(index) {

    const video = dailyVideos[index];

    titleEl.textContent = video.title;

    iframeEl.src =
      `https://www.youtube.com/embed/${video.id}?autoplay=0&rel=0&modestbranding=1&showinfo=0&controls=0&iv_load_policy=3`;

    iframeEl.classList.remove("hidden");
    skeletonEl.classList.add("hidden");

    counterEl.textContent =
      `${index + 1} / ${dailyVideos.length}`;

    prevBtn.disabled = index === 0;
    nextBtn.disabled = index === dailyVideos.length - 1;
  }


  nextBtn.addEventListener("click", () => {

    if (currentVideo < dailyVideos.length - 1) {
      currentVideo++;
      showVideo(currentVideo);
    }

  });


  prevBtn.addEventListener("click", () => {

    if (currentVideo > 0) {
      currentVideo--;
      showVideo(currentVideo);
    }

  });


  showVideo(currentVideo);

}


loadDailyVideos();

</script>