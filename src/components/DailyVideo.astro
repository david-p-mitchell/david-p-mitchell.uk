---
interface Video {
  id: string;
  title: string;
}

const PLAYLIST_ID = "PL4eoRWZvm-i1RhwritYSbfqVCTD8jDmQV";

// Fetch YouTube playlist RSS feed
const res = await fetch(
  `https://www.youtube.com/feeds/videos.xml?playlist_id=${PLAYLIST_ID}`
);

const xml = await res.text();

// Helper to decode XML entities
const decode = (str: string) =>
  str
    .replace(/&amp;/g, "&")
    .replace(/&quot;/g, '"')
    .replace(/&#39;/g, "'")
    .replace(/&lt;/g, "<")
    .replace(/&gt;/g, ">");

// Extract each <entry> block
const entryMatches = [...xml.matchAll(/<entry>([\s\S]*?)<\/entry>/g)];

const videos: Video[] = entryMatches
  .map((entry) => {
    const block = entry[1];

    const idMatch = block.match(/<yt:videoId>(.*?)<\/yt:videoId>/);
    const titleMatch = block.match(/<title>(.*?)<\/title>/);

    const id = idMatch?.[1];
    const title = titleMatch?.[1];

    if (!id) return null;

    return {
      id,
      title: decode(title ?? "YouTube Video"),
    };
  })
  .filter(Boolean) as Video[];

// Deterministic daily video based on days since Unix epoch
const daysSinceEpoch = Math.floor(Date.now() / 86_400_000);

const video =
  videos.length > 0
    ? videos[daysSinceEpoch % videos.length]
    : null;
---

<section class="bg-card border border-border sm:rounded-lg lg:rounded-2xl overflow-hidden flex flex-col max-w-md">
  <p class="font-mono text-xs uppercase tracking-widest text-gold-muted mt-4 ml-4">
    Today's Video Encouragement
  </p>

  <p class="font-display font-semibold text-sm text-text-primary leading-snug ml-4">
    {video?.title}
  </p>

  <div class="relative max-w-md aspect-video">
    <iframe
      src={`https://www.youtube.com/embed/${video?.id}?autoplay=0&rel=0&modestbranding=1&showinfo=0&controls=0&iv_load_policy=3`}
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      class="w-full h-full border-0"
    ></iframe>
  </div>
</section>