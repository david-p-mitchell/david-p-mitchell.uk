---
// Each entry is a YouTube video ID + title + optional description
// The video shown rotates daily based on the day of the year
interface Video {
  id: string;       // YouTube video ID (e.g. "dQw4w9WgXcQ")
  title: string;
  description?: string;
}

interface Props {
  videos: Video[];
}

const { videos } = Astro.props;

// Pick today's video deterministically from the pool
const dayOfYear = Math.floor(
  (Date.now() - new Date(new Date().getFullYear(), 0, 0).getTime()) / 86_400_000
);
const video = videos[dayOfYear % videos.length];
const embedUrl = `https://www.youtube.com/embed/shorts/${video.id}?playlist=${video.id}`;
---

<section class="bg-card border border-border rounded-2xl overflow-hidden flex flex-col w-sm">

    <p class="font-mono text-xs uppercase tracking-widest text-gold-muted mt-4 ml-4">Today's Video Encouragement</p>
    <p class="font-display font-semibold text-sm text-text-primary leading-snug ml-4">{video.title}</p>
  <!-- 16:9 embed -->
  <div class="relative w-sm h-max-[300px] h-[300px]  aspect-video">
    <iframe
  src={`https://www.youtube.com/embed/${video.id}?wmode=opaque&autoplay=0&playlist=${video.id}&widgetid=1&vf=6`}
  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
  class="w-full h-full  border-0"
></iframe>
  </div>

  <!-- Caption -->
  <div class="p-5 flex flex-col gap-1.5">
    {video.description && (
      <p class="font-serif text-xs text-text-secondary leading-relaxed">{video.description}</p>
    )}
  </div>

</section>