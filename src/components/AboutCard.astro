---
interface Props { name: string; role: string; bio: string; imageSrc?: string; }
const { name, role, bio, imageSrc = "/images/profile.jpg" } = Astro.props;
import styles from '../styles/global.css';
---

<div class="flex">
<div class="shimmer h-full rounded-[20px] p-4 flex flex-col gap-6
            bg-card border border-rim
            transition-shadow duration-300 hover:shadow-gold bg-blue-950 text-gray-200">
  
<div class="flex justify-between">
  <div class="relative w-[85px] h-[85px] shrink-0">
    <img
      src={imageSrc}
      alt={`Photo of ${name}`}
      class="relative z-10 w-[86px] h-[86px] rounded-full object-cover"
    />
    <div class="photo-ring"></div>
    
  </div>
  <div class="text-right">
    <span class="block font-mono  font-semibold uppercase tracking-widest text-xs text-gold">
      About Me
    </span>
    <h2 class="font-display text-3xl leading-tight text-text-primary mt-1 mb-1">
      {name}
    </h2>
    <p class="font-mono text-xs tracking-wider text-gold mb-3">
      {role}
    </p>
    </div>
  </div>

  <div class="">
    
    <p class="text-sm leading-relaxed text-text-secondary">
      {bio}
    </p>
  </div>
  
  </div>
</div>