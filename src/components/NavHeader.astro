---
import { links as navLinks, type NavLink } from "../data/nav";

export interface Props {
  siteName?: string;
  links?: NavLink[];
}

const {
  siteName = "David Mitchell",
  links = navLinks,
} = Astro.props;

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-[100] bg-blue-950 text-white dark:bg-gray-900">
  <div class="relative mx-auto flex max-w-[1200px] items-center gap-8">
    <a
      href="/"
      class="whitespace-nowrap pl-2 text-[1.1rem] font-semibold text-gray-100 no-underline dark:text-gray-50"
    >
      {siteName}
    </a>

    <button
      class="nav-toggle ml-auto flex flex-col justify-center gap-[5px] p-2 md:hidden"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <span class="block h-[1.5px] w-[22px] rounded bg-gray-100 transition-all dark:bg-gray-50"></span>
      <span class="block h-[1.5px] w-[22px] rounded bg-gray-100 transition-all dark:bg-gray-50"></span>
      <span class="block h-[1.5px] w-[22px] rounded bg-gray-100 transition-all dark:bg-gray-50"></span>
    </button>

    <nav
      id="nav-links"
      class="hidden absolute top-full left-0 right-0 flex-col items-stretch bg-blue-950 px-4 py-3 shadow-lg md:static md:ml-auto md:flex md:flex-row md:items-center md:gap-1 md:bg-transparent md:p-0 md:shadow-none"
    >
      {
        links.map((link) =>
          "children" in link && link.children ? (
            <details class="group md:relative">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-1 rounded-md px-3 py-3 text-left text-[0.9rem] font-normal text-gray-100 transition-colors hover:bg-gray-100 hover:text-gray-900 [&::-webkit-details-marker]:hidden dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-gray-50 md:py-1.5">
                {link.label}
                <svg
                  class="h-3 w-3 shrink-0 transition-transform group-open:rotate-180"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>

              <div class="flex flex-col pb-1 pl-3 md:absolute md:left-0 md:top-full md:min-w-[200px] md:flex-col md:gap-0.5 md:rounded-md md:bg-blue-950 md:p-1 md:pl-1 md:shadow-lg dark:md:bg-gray-900">
                {link.children.map((child) => (
                  <a 
                    href={child.href}
                    class:list={[
                      "block rounded-md px-3 py-2 text-left text-[0.9rem] font-normal text-gray-200 transition-colors hover:bg-gray-100 hover:text-gray-900 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-gray-50",
                      {
                        "font-medium text-white dark:text-gray-50":
                          currentPath === child.href,
                      },
                    ]}
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </details>
          ) : (
            <a
              href={link.href}
              class:list={[
                "block rounded-md px-3 py-3 text-left text-[0.9rem] font-normal text-gray-100 transition-colors hover:bg-gray-100 hover:text-gray-900 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-gray-50 md:py-1.5",
                {
                  "font-medium text-white dark:text-gray-50":
                    currentPath === link.href,
                },
              ]}
            >
              {link.label}
            </a>
          )
        )
      }
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector(".nav-toggle");
  const nav = document.getElementById("nav-links");

  toggle?.addEventListener("click", () => {
    nav?.classList.toggle("hidden");

    const isOpen = !nav?.classList.contains("hidden");
    toggle.setAttribute("aria-expanded", String(isOpen));
  });

  // Ensure menu is reset when resizing to desktop
  window.addEventListener("resize", () => {
    if (window.innerWidth >= 768) {
      nav?.classList.remove("hidden");
    } else {
      nav?.classList.add("hidden");
      toggle?.setAttribute("aria-expanded", "false");
    }
    closeAllDropdowns();
  });

  function closeAllDropdowns(except?: HTMLDetailsElement) {
    nav?.querySelectorAll("details[open]").forEach((details) => {
      if (details !== except) details.removeAttribute("open");
    });
  }

  // Close other dropdowns when one opens, and close on outside click
  nav?.querySelectorAll("details").forEach((details) => {
    details.addEventListener("toggle", () => {
      if (details.open) closeAllDropdowns(details);
    });
  });

  document.addEventListener("click", (e) => {
    if (!nav?.contains(e.target as Node)) closeAllDropdowns();
  });
</script>