---
export interface Props {
  siteName?: string;
  links?: { label: string; href: string }[];
}

const {
  siteName = "David Mitchell",
  links = [
    { label: "Home", href: "/" },
    { label: "Media", href: "/media" },
    { label: "Blog", href: "/blog" },
  ],
} = Astro.props;

const currentPath = Astro.url.pathname;
---

<header class="nav-header">
  <div class="nav-inner">
    <a href="/" class="nav-logo pl-2">{siteName}</a>

    <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>

    <nav class="nav-links" id="nav-links">
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={["nav-link", { active: currentPath === link.href }]}
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<style>
  .nav-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: white;
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    height: 60px;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-logo {
    font-size: 1.1rem;
    font-weight: 600;
    color: #111827;
    text-decoration: none;
    white-space: nowrap;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-left: auto;
  }

  .nav-link {
    font-size: 0.9rem;
    font-weight: 400;
    color: #6b7280;
    text-decoration: none;
    padding: 0.4rem 0.75rem;
    border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }

  .nav-link:hover {
    color: #111827;
    background: #f3f4f6;
  }

  .nav-link.active {
    color: #111827;
    font-weight: 500;
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
    margin-left: auto;
  }

  .bar {
    display: block;
    width: 22px;
    height: 1.5px;
    background: #111827;
    border-radius: 2px;
    transition: transform 0.2s, opacity 0.2s;
  }

  @media (max-width: 640px) {
    .nav-toggle {
      display: flex;
    }

    .nav-links {
      display: none;
      position: absolute;
      top: 60px;
      left: 0;
      right: 0;
      background: white;
      border-bottom: 0.5px solid #e5e7eb;
      flex-direction: column;
      align-items: stretch;
      padding: 0.75rem 1.5rem 1rem;
      gap: 0.25rem;
      margin-left: 0;
    }

    .nav-links.open {
      display: flex;
    }

    .nav-link,
    .nav-cta {
      padding: 0.6rem 0.75rem;
      font-size: 0.95rem;
    }

    .nav-cta {
      margin-left: 0;
      text-align: center;
      margin-top: 0.25rem;
    }
  }

  @media (prefers-color-scheme: dark) {
    .nav-header {
      background: #111827;
      border-bottom-color: #374151;
    }
    .nav-logo {
      color: #f9fafb;
    }
    .nav-link {
      color: #9ca3af;
    }
    .nav-link:hover {
      color: #f9fafb;
      background: #1f2937;
    }
    .nav-link.active {
      color: #f9fafb;
    }
    .nav-cta {
      background: #f9fafb;
      color: #111827;
    }
    .nav-cta:hover {
      background: #e5e7eb;
    }
    .bar {
      background: #f9fafb;
    }
    .nav-links {
      background: #111827;
      border-bottom-color: #374151;
    }
  }
</style>

<script>
  const toggle = document.querySelector(".nav-toggle");
  const nav = document.getElementById("nav-links");

  toggle?.addEventListener("click", () => {
    const isOpen = nav?.classList.toggle("open");
    toggle.setAttribute("aria-expanded", String(isOpen));
  });
</script>