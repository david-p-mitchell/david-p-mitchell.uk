---
export interface Props {
  siteName?: string;
  links?: { label: string; href: string }[];
}

const {
  siteName = "David Mitchell",
  links = [
    { label: "Home", href: "/" },
    { label: "Media", href: "/media" },
    { label: "Blog", href: "/blog" },
  ],
} = Astro.props;

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-[100] bg-blue-950 text-white dark:bg-gray-900">
  <div class="mx-auto flex  max-w-[1200px] items-center gap-8">
    <a
      href="/"
      class="whitespace-nowrap pl-2 text-[1.1rem] font-semibold text-gray-100 no-underline dark:text-gray-50"
    >
      {siteName}
    </a>

    <button
      class="nav-toggle ml-auto hidden flex-col justify-center gap-[5px] p-1 sm:hidden"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <span class="block h-[1.5px] w-[22px] rounded bg-gray-900 transition-all dark:bg-gray-50"></span>
      <span class="block h-[1.5px] w-[22px] rounded bg-gray-900 transition-all dark:bg-gray-50"></span>
      <span class="block h-[1.5px] w-[22px] rounded bg-gray-900 transition-all dark:bg-gray-50"></span>
    </button>

    <nav
      id="nav-links"
      class="nav-links ml-auto flex items-center gap-1
             max-sm:hidden
             max-sm:absolute
             max-sm:top-[60px]
             max-sm:left-0
             max-sm:right-0
             max-sm:flex-col
             max-sm:items-stretch
             max-sm:bg-white
             max-sm:px-6
             max-sm:pt-3
             max-sm:pb-4
             max-sm:dark:bg-gray-900"
    >
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={[
              "rounded-md px-3 py-1.5 text-[0.9rem] font-normal text-gray-100 transition-colors hover:bg-gray-100 hover:text-gray-900 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-gray-50",
              {
                "font-medium text-gray-100 dark:text-gray-50":
                  currentPath === link.href,
              },
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector(".nav-toggle");
  const nav = document.getElementById("nav-links");

  toggle?.addEventListener("click", () => {
    const isOpen = nav?.classList.toggle("max-sm:flex");
    nav?.classList.toggle("max-sm:hidden");

    toggle.setAttribute("aria-expanded", String(isOpen));
  });
</script>